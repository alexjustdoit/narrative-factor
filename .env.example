# Copy to .env and fill in your values

# Anthropic API key (required for anthropic backend)
ANTHROPIC_API_KEY=your-key-here

# SEC EDGAR contact email (required by SEC fair-use policy)
EDGAR_EMAIL=your-email@example.com

# Backend: "anthropic" (default) or "local"
SCORER_BACKEND=anthropic

# Anthropic model — use haiku for backtest iteration, sonnet for validation
SCORER_MODEL=claude-sonnet-4-6

# Local LLM settings (only needed when SCORER_BACKEND=local)
# For a single machine, point at the local Ollama instance:
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=qwen3.6:35b

# For a multi-node cluster, comma-separate multiple Ollama endpoints:
# LOCAL_LLM_BASE_URL=http://192.168.1.2:11434/v1,http://192.168.1.3:11434/v1

# Number of parallel workers for --backfill.
# Auto-detected via nvidia-smi for NVIDIA discrete GPUs.
# Set manually for APU/Strix nodes (not visible to nvidia-smi):
# BACKFILL_WORKERS=14
